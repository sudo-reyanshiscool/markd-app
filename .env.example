# ── Client (EXPO_PUBLIC_* ships in the bundle — publishable values only) ──
# Without these the app still runs fully in demo/guest mode.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Web origin used for share links + Stripe redirects
EXPO_PUBLIC_APP_WEB_URL=https://markd.vercel.app

# Optional observability (analytics stays off until in-app consent)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# RevenueCat public SDK keys (mobile paywall)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# ── Server secrets (NEVER EXPO_PUBLIC_*) ─────────────────────────────────
# Set with: supabase secrets set KEY=value
# Full table + purpose: supabase/functions/SETUP.md
# ANTHROPIC_API_KEY, ANTHROPIC_MODEL_SONNET, ANTHROPIC_MODEL_HAIKU,
# CRON_SECRET, APP_WEB_URL,
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
# STRIPE_PRICE_PRO_MONTHLY, STRIPE_PRICE_PRO_YEARLY, STRIPE_PRICE_FAMILY_YEARLY,
# REVENUECAT_API_KEY, RC_WEBHOOK_AUTH
